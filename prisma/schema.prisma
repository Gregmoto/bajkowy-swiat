// Prisma schema — Bajkowy Świat
// Dokumentacja: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooler URL — używany w runtime (queries)
  directUrl = env("DIRECT_URL")     // bezpośredni URL — używany przez `prisma migrate`
}

// ---------------------------------------------------------------------------
// USER
// ---------------------------------------------------------------------------
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?                   // null gdy logowanie OAuth
  name         String
  emailVerified DateTime?
  image        String?
  role         UserRole  @default(USER)
  isBanned     Boolean   @default(false) // zablokowany przez admina

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lastActiveAt DateTime?                   // ostatnia aktywność (login / akcja)

  // relacje
  profiles     ChildProfile[]
  stories      Story[]
  subscription Subscription?
  auditLogs    AuditLog[]
  reports      Report[]
  payments     Payment[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// CHILD PROFILE
// ---------------------------------------------------------------------------
model ChildProfile {
  id             String   @id @default(cuid())
  userId         String
  name           String
  age            Int
  gender         Gender
  interests      String[]             // lista zainteresowań dziecka
  favoriteColor  String?
  favoriteAnimal String?
  avatar         String?              // emoji lub URL awatara
  notes          String?  @db.Text   // dodatkowe notatki rodzica

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // relacje
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories        Story[]

  @@index([userId])
  @@map("child_profiles")
}

enum Gender {
  BOY    // chłopiec
  GIRL   // dziewczynka
  OTHER  // inne / nie podano
}

// ---------------------------------------------------------------------------
// STORY
// ---------------------------------------------------------------------------
model Story {
  id             String      @id @default(cuid())
  userId         String
  childProfileId String

  // metadane bajki
  title          String
  theme          StoryTheme
  summary        String?     @db.Text  // krótki opis (1–2 zdania)
  content        String?     @db.Text  // aktualny tekst bajki (cache ostatniej wersji)
  coverImage     String?               // URL okładki / emoji
  language       String      @default("pl")
  status         StoryStatus @default(DRAFT)

  // parametry generacji (snapshot w chwili tworzenia)
  moral          String?
  extra          String?     @db.Text

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // relacje
  user           User         @relation(fields: [userId],         references: [id], onDelete: Cascade)
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  versions       StoryVersion[]
  likes          StoryLike[]
  tags           StoryTag[]

  @@index([userId])
  @@index([childProfileId])
  @@index([status])
  @@map("stories")
}

enum StoryTheme {
  ADVENTURE   // przygoda
  MAGIC       // magia
  FRIENDSHIP  // przyjaźń
  ANIMALS     // zwierzęta
  SPACE       // kosmos
  FAIRY_TALE  // bajka klasyczna
  NATURE      // przyroda
}

enum StoryStatus {
  DRAFT      // generowanie w toku / błąd
  PUBLISHED  // gotowa do czytania
  ARCHIVED   // ukryta w archiwum
}

// ---------------------------------------------------------------------------
// STORY VERSION
// ---------------------------------------------------------------------------
// Każda (re)generacja bajki = nowa wersja. Story.content = cache najnowszej.
model StoryVersion {
  id         String   @id @default(cuid())
  storyId    String
  version    Int                       // 1, 2, 3 …
  content    String   @db.Text         // pełny tekst tej wersji
  summary    String?  @db.Text         // podsumowanie tej wersji
  modelId    String?                   // np. "claude-opus-4-6"
  promptHash String?                   // hash promptu (debug/cache)
  tokens     Int?                      // zużyte tokeny

  createdAt  DateTime @default(now())

  // relacje
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, version])
  @@index([storyId])
  @@map("story_versions")
}

// ---------------------------------------------------------------------------
// STORY LIKE  (ulubione bajki)
// ---------------------------------------------------------------------------
model StoryLike {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())

  story     Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([userId])
  @@map("story_likes")
}

// ---------------------------------------------------------------------------
// STORY TAG  (tagi / kategorie)
// ---------------------------------------------------------------------------
model StoryTag {
  id      String @id @default(cuid())
  storyId String
  tag     String

  story   Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, tag])
  @@index([tag])
  @@map("story_tags")
}

// ---------------------------------------------------------------------------
// SUBSCRIPTION  (plany abonamentowe)
// ---------------------------------------------------------------------------
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)

  // Stripe — wypełniane przy upgradzie
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)

  storiesThisMonth     Int                @default(0)  // licznik miesięczny
  storiesResetAt       DateTime?                       // kiedy wyzerować licznik

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // relacje
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE      // 5 bajek / miesiąc, 1 profil dziecka
  STARTER   // 20 bajek / miesiąc, 3 profile
  PREMIUM   // nieograniczony, 10 profili
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

// ---------------------------------------------------------------------------
// PAYMENT  (historia płatności)
// ---------------------------------------------------------------------------
model Payment {
  id              String        @id @default(cuid())
  userId          String
  amount          Int           // w groszach, np. 4900 = 49 zł
  currency        String        @default("PLN")
  status          PaymentStatus @default(PENDING)
  stripePaymentId String?       @unique
  description     String?       // np. "Starter — styczeń 2026"

  createdAt       DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ---------------------------------------------------------------------------
// REPORT  (zgłoszenia użytkowników)
// ---------------------------------------------------------------------------
model Report {
  id           String       @id @default(cuid())
  userId       String?
  type         ReportType
  subject      String
  description  String       @db.Text
  status       ReportStatus @default(OPEN)
  resolvedById String?                   // userId admina, który zamknął zgłoszenie
  resolvedAt   DateTime?
  adminNote    String?      @db.Text    // notatka admina

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@map("reports")
}

enum ReportType {
  BUG       // błąd techniczny
  CONTENT   // nieodpowiednia treść bajki
  BILLING   // problem z płatnością
  OTHER     // inne
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ---------------------------------------------------------------------------
// AUDIT LOG
// ---------------------------------------------------------------------------
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?                    // null dla zdarzeń anonimowych
  action     String                     // np. "story.create", "user.login"
  resource   String?                    // np. "Story", "ChildProfile"
  resourceId String?                    // id zmienionego rekordu
  metadata   Json?                      // dowolne dane kontekstowe
  ipAddress  String?
  userAgent  String?

  createdAt  DateTime @default(now())

  // relacje
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
