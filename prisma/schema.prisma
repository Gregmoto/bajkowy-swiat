// Prisma schema — Bajkowy Świat
// Dokumentacja: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooler URL — używany w runtime (queries)
  directUrl = env("DIRECT_URL")     // bezpośredni URL — używany przez `prisma migrate`
}

// ---------------------------------------------------------------------------
// USER
// ---------------------------------------------------------------------------
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?                   // null gdy logowanie OAuth
  name         String
  emailVerified DateTime?
  image        String?
  role         UserRole  @default(USER)
  isBanned     Boolean   @default(false)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lastActiveAt      DateTime?
  adminNote         String?   @db.Text
  flaggedForReview  Boolean   @default(false)

  // relacje
  profiles         ChildProfile[]
  stories          Story[]
  subscription     Subscription?
  auditLogs        AuditLog[]
  reports          Report[]
  payments         Payment[]
  invoices         Invoice[]
  adminNotesTarget AdminNote[]       @relation("UserAdminNotes")
  adminNotesAuthor AdminNote[]       @relation("AuthoredAdminNotes")
  activityLogs     UserActivityLog[]
  supportTickets   SupportTicket[]
  refundRequests   RefundRequest[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// CHILD PROFILE
// ---------------------------------------------------------------------------
model ChildProfile {
  id             String   @id @default(cuid())
  userId         String
  name           String
  age            Int
  gender         Gender
  interests      String[]
  favoriteColor  String?
  favoriteAnimal String?
  avatar         String?
  notes          String?  @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories        Story[]

  @@index([userId])
  @@map("child_profiles")
}

enum Gender {
  BOY
  GIRL
  OTHER
}

// ---------------------------------------------------------------------------
// STORY
// ---------------------------------------------------------------------------
model Story {
  id             String      @id @default(cuid())
  userId         String
  childProfileId String

  title          String
  theme          StoryTheme
  summary        String?     @db.Text
  content        String?     @db.Text
  coverImage     String?
  language       String      @default("pl")
  status         StoryStatus @default(DRAFT)

  moral                String?
  extra                String?     @db.Text
  flaggedForModeration Boolean     @default(false)

  createdAt            DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User         @relation(fields: [userId],         references: [id], onDelete: Cascade)
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  versions       StoryVersion[]
  likes          StoryLike[]
  tags           StoryTag[]

  @@index([userId])
  @@index([childProfileId])
  @@index([status])
  @@map("stories")
}

enum StoryTheme {
  ADVENTURE
  MAGIC
  FRIENDSHIP
  ANIMALS
  SPACE
  FAIRY_TALE
  NATURE
}

enum StoryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// STORY VERSION
// ---------------------------------------------------------------------------
model StoryVersion {
  id         String   @id @default(cuid())
  storyId    String
  version    Int
  content    String   @db.Text
  summary    String?  @db.Text
  modelId    String?
  promptHash String?
  tokens     Int?

  createdAt  DateTime @default(now())

  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, version])
  @@index([storyId])
  @@map("story_versions")
}

// ---------------------------------------------------------------------------
// STORY LIKE
// ---------------------------------------------------------------------------
model StoryLike {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())

  story     Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([userId])
  @@map("story_likes")
}

// ---------------------------------------------------------------------------
// STORY TAG
// ---------------------------------------------------------------------------
model StoryTag {
  id      String @id @default(cuid())
  storyId String
  tag     String

  story   Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, tag])
  @@index([tag])
  @@map("story_tags")
}

// ---------------------------------------------------------------------------
// SUBSCRIPTION
// ---------------------------------------------------------------------------
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)

  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?

  billingPeriod        BillingPeriod      @default(MONTHLY)
  canceledAt           DateTime?
  notes                String?            @db.Text

  storiesThisMonth     Int                @default(0)
  storiesResetAt       DateTime?

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices             Invoice[]

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

// ---------------------------------------------------------------------------
// PAYMENT
// ---------------------------------------------------------------------------
model Payment {
  id              String        @id @default(cuid())
  userId          String
  amount          Int           // w groszach, np. 4900 = 49 zł
  currency        String        @default("PLN")
  status          PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(OTHER)
  type            String?       // "subscription" | "one_time" | "top_up"
  stripePaymentId String?       @unique
  stripeChargeId  String?       @unique
  description     String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice         Invoice?
  refundRequests  RefundRequest[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

enum PaymentMethod {
  CARD
  BLIK
  TRANSFER
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  OTHER
}

// ---------------------------------------------------------------------------
// INVOICE / BILLING RECORD
// ---------------------------------------------------------------------------
model Invoice {
  id              String        @id @default(cuid())
  userId          String
  subscriptionId  String?
  paymentId       String?       @unique
  number          String        @unique     // np. "FS/2026/001"
  amount          Int           // w groszach (kwota brutto)
  currency        String        @default("PLN")
  status          InvoiceStatus @default(DRAFT)
  taxRate         Decimal?      @db.Decimal(5, 2)  // np. 23.00
  taxAmount       Int?          // w groszach
  netAmount       Int?          // kwota netto w groszach
  description     String?
  buyerName       String?
  buyerAddress    String?       @db.Text
  buyerTaxId      String?       // NIP nabywcy

  stripeInvoiceId String?       @unique

  issuedAt        DateTime      @default(now())
  dueAt           DateTime?
  paidAt          DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment         Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([issuedAt])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

// ---------------------------------------------------------------------------
// ADMIN NOTE  (notes per user, written by admins)
// ---------------------------------------------------------------------------
model AdminNote {
  id        String   @id @default(cuid())
  userId    String                        // użytkownik, którego dotyczy notatka
  authorId  String                        // admin, który ją napisał
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  isPrivate Boolean  @default(true)       // widoczna tylko dla adminów

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserAdminNotes",    fields: [userId],   references: [id], onDelete: Cascade)
  author    User     @relation("AuthoredAdminNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([authorId])
  @@map("admin_notes")
}

// ---------------------------------------------------------------------------
// USER ACTIVITY LOG
// ---------------------------------------------------------------------------
model UserActivityLog {
  id        String          @id @default(cuid())
  userId    String
  type      ActivityLogType
  metadata  Json?           // dowolne dane kontekstowe (storyId, planId itp.)
  ipAddress String?
  userAgent String?
  sessionId String?

  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("user_activity_logs")
}

enum ActivityLogType {
  LOGIN
  LOGOUT
  STORY_CREATE
  STORY_VIEW
  STORY_REGENERATE
  STORY_DELETE
  STORY_SHARE
  PROFILE_CREATE
  PROFILE_UPDATE
  PROFILE_DELETE
  SUBSCRIPTION_UPGRADE
  SUBSCRIPTION_DOWNGRADE
  SUBSCRIPTION_CANCEL
  SUBSCRIPTION_RESTORE
  PAYMENT_INITIATED
  PAYMENT_SUCCESS
  PAYMENT_FAIL
  PASSWORD_CHANGE
  EMAIL_CHANGE
  ACCOUNT_DELETE
  SETTINGS_UPDATE
}

// ---------------------------------------------------------------------------
// SUPPORT TICKET
// ---------------------------------------------------------------------------
model SupportTicket {
  id          String         @id @default(cuid())
  userId      String?
  subject     String
  description String         @db.Text
  category    TicketCategory @default(OTHER)
  priority    TicketPriority @default(NORMAL)
  status      TicketStatus   @default(OPEN)
  assignedTo  String?        // userId admina
  resolvedAt  DateTime?
  closedAt    DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages    TicketMessage[]

  @@index([status])
  @@index([userId])
  @@index([priority])
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  authorId   String        // userId piszącego (user lub admin)
  content    String        @db.Text
  isInternal Boolean       @default(false)  // notatka wewnętrzna — tylko admini

  createdAt  DateTime      @default(now())

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

enum TicketCategory {
  BILLING
  TECHNICAL
  CONTENT
  ACCOUNT
  FEATURE_REQUEST
  OTHER
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_USER
  RESOLVED
  CLOSED
}

// ---------------------------------------------------------------------------
// REFUND REQUEST
// ---------------------------------------------------------------------------
model RefundRequest {
  id             String       @id @default(cuid())
  userId         String
  paymentId      String
  amount         Int          // kwota zwrotu w groszach (może być częściowa)
  reason         String       @db.Text
  status         RefundStatus @default(PENDING)
  adminNote      String?      @db.Text
  stripeRefundId String?      @unique
  processedAt    DateTime?
  processedBy    String?      // userId admina

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId],    references: [id], onDelete: Cascade)
  payment        Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("refund_requests")
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
  FAILED
}

// ---------------------------------------------------------------------------
// SYSTEM EVENT LOG
// ---------------------------------------------------------------------------
model SystemEventLog {
  id        String          @id @default(cuid())
  type      SystemEventType
  severity  EventSeverity   @default(INFO)
  message   String
  metadata  Json?
  source    String?         // np. "stripe-webhook", "cron", "api", "admin"
  traceId   String?         // korelacja zdarzeń w jednej operacji

  createdAt DateTime        @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@map("system_event_logs")
}

enum SystemEventType {
  STRIPE_WEBHOOK
  PAYMENT_PROCESSED
  PAYMENT_FAILED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_EXPIRED
  SUBSCRIPTION_CREATED
  INVOICE_GENERATED
  REFUND_PROCESSED
  EMAIL_SENT
  EMAIL_FAILED
  CRON_JOB_START
  CRON_JOB_END
  RATE_LIMIT_HIT
  SECURITY_ALERT
  DEPLOYMENT
  ERROR
  INFO
}

enum EventSeverity {
  DEBUG
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ---------------------------------------------------------------------------
// REPORT  (zgłoszenia — stary model, zastępowany przez SupportTicket)
// ---------------------------------------------------------------------------
model Report {
  id           String       @id @default(cuid())
  userId       String?
  type         ReportType
  subject      String
  description  String       @db.Text
  status       ReportStatus @default(OPEN)
  resolvedById String?
  resolvedAt   DateTime?
  adminNote    String?      @db.Text

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@map("reports")
}

enum ReportType {
  BUG
  CONTENT
  BILLING
  OTHER
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ---------------------------------------------------------------------------
// AUDIT LOG  (systemowy log akcji adminów i krytycznych zdarzeń)
// ---------------------------------------------------------------------------
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String                     // np. "user.ban", "story.delete"
  resource   String?                    // np. "User", "Story"
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// SYSTEM SETTING  (konfiguracja platformy zarządzana przez admina)
// ---------------------------------------------------------------------------
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique            // np. "app.name", "plan.free.storiesPerMonth"
  value     Json                        // wartość — string, number, array, object
  label     String?                     // etykieta dla UI admina
  group     String?                     // sekcja: "app", "seo", "plans", "limits", "faq", "legal"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("system_settings")
}
