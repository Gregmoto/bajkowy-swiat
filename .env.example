# ============================================================
# BAJKOWY ŚWIAT — zmienne środowiskowe
# Skopiuj ten plik do .env.local i uzupełnij wartości.
# NIGDY nie commituj .env ani .env.local do repozytorium!
# ============================================================

# ------------------------------------------------------------
# BAZA DANYCH — Neon PostgreSQL
# Pobierz z: https://console.neon.tech → Connection Details
# ------------------------------------------------------------

# URL poolera (PgBouncer) — używany przez aplikację w runtime
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Bezpośredni URL — używany przez `prisma migrate deploy` i `prisma db push`
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ------------------------------------------------------------
# AUTENTYKACJA — JWT
# Wygeneruj sekret: openssl rand -base64 32
# ------------------------------------------------------------
NEXTAUTH_SECRET="zamien-na-bezpieczny-sekret-minimum-32-znaki"

# URL aplikacji (http://localhost:3000 lokalnie, https://twoja-domena.vercel.app na produkcji)
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# ANTHROPIC AI — opcjonalne (generator lokalny działa bez klucza)
# Pobierz z: https://console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."

# ------------------------------------------------------------
# VERCEL BLOB — storage zdjęć i ilustracji
# Dodaj integrację Vercel Blob w dashboardzie Vercel:
# Project → Storage → Connect Store → Blob
# Klucz zostanie dodany automatycznie jako BLOB_READ_WRITE_TOKEN
# ------------------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ------------------------------------------------------------
# REPLICATE AI — generowanie ilustracji bajkowych
# Pobierz z: https://replicate.com/account/api-tokens
# Opcjonalne — bez klucza ilustracje będą niedostępne (status: FAILED)
# ------------------------------------------------------------
REPLICATE_API_TOKEN="r8_..."

# Opcjonalnie: własna wersja modelu Replicate (img2img cartoonify)
# Domyślnie: catacolabs/cartoonify
# REPLICATE_MODEL_VERSION="2e112284f006bcd1e5c2f80b890a35f4ef58f2e9339e4e76a0c40dc4e25bfbdd"
